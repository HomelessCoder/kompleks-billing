            "LanBilling\\Tests\\": "tests/"
        }
    },
    "require": {
        "power-modules/framework": "^2.2",
        "power-modules/persistence": "^0.4.2",
        "vlucas/phpdotenv": "^5.6",
        "power-modules/console": "^0.3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1",
        "friendsofphp/php-cs-fixer": "^3.95"
    }
}